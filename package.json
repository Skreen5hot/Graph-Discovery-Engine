{
  "name": "graph-discovery-engine",
  "version": "0.0.0",
  "description": "GDE v2.1 — RPM Discovery-First engine and Query Builder UI for deterministic graph pattern expansion",
  "type": "module",
  "main": "dist/kernel/index.js",
  "types": "dist/kernel/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/kernel/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "verify": "npm run build && npm test && npm run test:purity",
    "demo": "node dist/demo.js",
    "clean": "rimraf dist dist-tests"
  },
  "keywords": [
    "json-ld",
    "deterministic",
    "graph-discovery",
    "sparql",
    "knowledge-graph",
    "query-builder",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
